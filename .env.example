# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-01

# Password shown on the Streamlit login screen.
# Leave empty to disable the gate (local dev only).
APP_PASSWORD=your-password-here

# GitHub API — used by the "Refresh now" button to trigger the Actions workflow.
# GITHUB_TOKEN: a Personal Access Token with Actions: write scope.
# GITHUB_REPO: owner/repo format, e.g. SleepyFluffy98/genai-radar
GITHUB_TOKEN=your-github-pat-here
GITHUB_REPO=SleepyFluffy98/genai-radar

# Supabase — for persistent per-user favorites and profiles
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
